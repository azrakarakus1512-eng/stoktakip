<button class="w-full bg-primary-container text-on-primary-container py-4 rounded-xl font-headline-sm flex items-center justify-center gap-2 shadow-sm active:scale-95 transition-transform">
<span class="material-symbols-outlined" data-icon="edit">edit</span>
