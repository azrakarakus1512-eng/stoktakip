</button>
<h1 class="text-headline-sm font-headline-sm font-bold text-on-surface dark:text-on-surface tracking-tight">ÜRÜN DETAY</h1>
<button class="text-primary dark:text-primary-fixed-dim hover:opacity-80 transition-opacity Active: scale-95 duration-100 flex items-center justify-center">
<span class="material-symbols-outlined" data-icon="settings">settings</span>
</button>
</header>
<main class="mt-16 px-5 space-y-4">
<!-- Product Header Card -->
<section class="glass-card rounded-xl p-5 mt-4">
<div class="flex flex-col items-center mb-6">
<div class="w-48 h-48 rounded-lg overflow-hidden mb-4 bg-surface-container-highest">
<img class="w-full h-full object-contain" data-alt="A high-quality studio photograph of a modern slate blue smartphone, featuring a sleek design with multiple camera lenses on the back. The lighting is soft and professional, highlighting the metallic finish and glass textures against a clean, minimalist light-colored background. The overall aesthetic is premium, clean, and modern, fitting a high-end inventory management interface." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDb4oVN-sADgQTwcLe8f3PMDlbjfyWVDnEpV05wlIOJiMxS8flPqKIQPTCTKthJVZApaPz1i3VhE9uRqKLmza_34ILF6FlTtaT4b9CGFws0tcZMelnunsxaP7PP79Fmcy5BB7fqDlcUs_vtDReU0Bq7xOz4tcp6gz9S8X39K1lxaq-uXJWSVvQC9QL7fAD4sFwQBKa3SZ3iWyEKUR54BMse49lRHIS2N6jMvnO-XychdWVZkAjLBVuyCApBLDhkskdnTuBZW3cQqUkX"/>
</div>
<div class="grid grid-cols-2 gap-y-4 w-full border-t border-outline-variant pt-4 mt-2"><div><p class="text-label-md font-label-md text-on-surface-variant uppercase opacity-70">MARKA</p><p class="text-body-lg font-headline-sm text-on-surface" data-field="Urunler.Marka">Apple iPhone 13</p></div><div class="text-right"><p class="text-label-md font-label-md text-on-surface-variant uppercase opacity-70">MODEL</p><p class="text-body-lg font-headline-sm text-on-surface" data-field="Urunler.Model">13</p></div><div><p class="text-label-md font-label-md text-on-surface-variant uppercase opacity-70">SERİ NO</p><p class="text-body-md font-body-md text-on-surface" data-field="Urunler.SeriNo">SE513820</p></div><div class="text-right"><p class="text-label-md font-label-md text-on-surface-variant uppercase opacity-70">STOK ADET</p><p class="text-display-lg font-display-lg text-primary" data-field="Urunler.StokAdet">2</p></div></div>
</div>
</section>
<!-- Sales Info Section -->
<section class="glass-card rounded-xl p-5">
<div class="flex items-center gap-2 mb-4 border-b border-outline-variant pb-2">
<span class="material-symbols-outlined text-primary text-xl" data-icon="payments">payments</span>
<h2 class="text-headline-sm font-headline-sm text-on-surface uppercase tracking-wide">SATIŞ BİLGİSİ</h2>
</div>
<div class="space-y-3"><div class="flex justify-between items-center"><span class="text-body-md font-body-md text-on-surface-variant">Satışı Kim Yaptı:</span><span class="text-body-md font-headline-sm text-on-surface" data-field="Satislar.SatisYapan">Mert Yılmaz</span></div><div class="flex justify-between items-center"><span class="text-body-md font-body-md text-on-surface-variant">Nereye Yaptı:</span><span class="text-body-md font-headline-sm text-on-surface" data-field="Satislar.Sube">TeknoPark Şubesi</span></div><div class="flex justify-between items-center"><span class="text-body-md font-body-md text-on-surface-variant">Ne Sattı:</span><span class="text-body-md font-headline-sm text-on-surface" data-field="Satislar.Miktar">2 Adet</span></div></div>
</section>
<!-- Transaction History -->
<section class="space-y-2">
<h3 class="px-1 text-label-md font-label-md text-on-surface-variant uppercase tracking-widest">GEÇMİŞ İŞLEMLER</h3>
<div class="glass-card rounded-xl overflow-hidden divide-y divide-outline-variant"><div class="p-4 flex justify-between items-center bg-white/40 hover:bg-white/60 transition-colors" data-repeat="Satislar"><div data-filter="urun_id = {{urun_id}}"><p class="text-label-md font-label-md text-on-surface-variant">Satışı Kim Yaptı</p><p class="text-body-md font-body-md text-on-surface" data-field="Satislar.SatisYapan">Mert Yılmaz</p></div><div class="text-right"><p class="text-headline-sm font-headline-sm text-primary" data-field="Satislar.Miktar">2 Adet</p></div></div></div>
</section>
